commit 9bb148a3e849c003938c7b8360be6c1b60d88ebe
Author: zorrobyte <zorrobyte@gmail.com>
Date:   Sat Jul 4 14:53:16 2026 -0400

    evdi: set FOP_UNSIGNED_OFFSET so EVDI card open() works on 6.12
    
    Kernel 6.12's drm_open_helper() (drm_file.c:316) does
    WARN_ON_ONCE(!(filp->f_op->fop_flags & FOP_UNSIGNED_OFFSET)) and
    returns -EINVAL. The vendored EVDI driver uses a custom evdi_fops
    (not DEFINE_DRM_GEM_FOPS, which sets this flag on 6.12), so every
    open() of an EVDI /dev/dri/cardN failed with EINVAL.
    
    That single failure is the root cause of the black-screen Lindroid
    desktop: container create-disp can't open any evdi-lindroid card,
    spins retrying /sys/devices/evdi-lindroid/add (leaking dozens of
    cards), and kwin_wayland reports "failed to open drm device".
    
    Add .fop_flags = FOP_UNSIGNED_OFFSET under #ifdef so it still builds
    on older kernels.
    
    Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>

diff --git a/lindroid/evdi/evdi_lindroid_drv.c b/lindroid/evdi/evdi_lindroid_drv.c
index 5f4e7a2..cbd7b77 100644
--- a/lindroid/evdi/evdi_lindroid_drv.c
+++ b/lindroid/evdi/evdi_lindroid_drv.c
@@ -35,6 +35,10 @@ static const struct file_operations evdi_fops = {
 	.read = drm_read,
 #ifdef CONFIG_COMPAT
 	.compat_ioctl = drm_compat_ioctl,
+#endif
+	/* Kernel 6.12 drm_open_helper WARNs+EINVALs without this flag. */
+#ifdef FOP_UNSIGNED_OFFSET
+	.fop_flags = FOP_UNSIGNED_OFFSET,
 #endif
 };
 #endif
