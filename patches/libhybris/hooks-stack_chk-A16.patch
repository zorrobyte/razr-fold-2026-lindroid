+    HOOK_TO(__write_chk, _hybris_hook___write_chk),
+    HOOK_TO(__ctype_get_mb_cur_max, __ctype_get_mb_cur_max),
+    HOOK_TO(__ctype_b_loc, __ctype_b_loc),
+    HOOK_TO(__ctype_tolower_loc, __ctype_tolower_loc),
